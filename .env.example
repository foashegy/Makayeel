# ============================================================
# Makayeel — Environment variables
# Copy this file to .env and fill in real values.
# Never commit .env. Never log secrets.
# ============================================================

# ---- Database ------------------------------------------------
# Postgres 16 (local dev: docker-compose up, prod: Railway)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/makayeel?schema=public"

# ---- Auth.js (NextAuth v5) ----------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-32-bytes-of-random"
NEXTAUTH_URL="http://localhost:3000"

# ---- Google OAuth -------------------------------------------
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- Email (magic link + alerts) ----------------------------
# Option A: SMTP URL (e.g., Resend SMTP)
EMAIL_SERVER="smtp://resend:RESEND_KEY@smtp.resend.com:465"
EMAIL_FROM="Makayeel <no-reply@makayeel.com>"
# Option B: Resend SDK (preferred for alert emails)
RESEND_API_KEY=""

# ---- Admin / seed -------------------------------------------
ADMIN_EMAIL="admin@makayeel.com"

# ---- Cron protection ----------------------------------------
# Sent in Authorization: Bearer header by Vercel Cron
CRON_SECRET="replace-me-with-32-bytes-of-random"

# ---- Telegram bot (apps/bot) --------------------------------
# Create bot via @BotFather, paste token here.
TELEGRAM_BOT_TOKEN=""
# Production webhook URL; leave blank in dev to use polling.
TELEGRAM_WEBHOOK_URL=""

# ---- Public site URL (used for sitemaps, OG, emails) --------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
