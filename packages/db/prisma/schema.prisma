// Makayeel — Prisma schema
// Postgres 16 · Prisma 5 · cuid ids · Cairo-local price dates.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
  binaryTargets   = ["native", "rhel-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Users, accounts, sessions (Auth.js v5 compatible)
// -----------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
}

enum Locale {
  ar
  en
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  locale        Locale    @default(ar)
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  subscription Subscription?
  alerts       Alert[]
  apiKeys      ApiKey[]
  botLink      BotLink?
  watchlist    Watchlist[]
  accounts     Account[]
  sessions     Session[]
  enteredPrices Price[]  @relation("EnteredBy")
  formulas     Formula[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// -----------------------------------------------------------------------------
// Subscriptions (MVP: placeholder — payment wiring is Phase 2)
// -----------------------------------------------------------------------------

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

model Subscription {
  id              String    @id @default(cuid())
  userId          String    @unique
  plan            Plan      @default(FREE)
  startedAt       DateTime  @default(now())
  currentPeriodEnd DateTime?
  provider        String?   // "paymob" | "stripe" — populated in Phase 2
  providerId      String?   // external subscription id
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// Commodities (feed raw materials)
// -----------------------------------------------------------------------------

enum CommodityCategory {
  GRAINS
  PROTEINS
  BYPRODUCTS
  ADDITIVES
  OILS
  FINISHED_FEED
}

model Commodity {
  id           String            @id @default(cuid())
  slug         String            @unique
  nameAr       String
  nameEn       String
  category     CommodityCategory
  unit         String            @default("EGP/ton")
  iconKey      String?
  displayOrder Int               @default(0)
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  prices     Price[]
  alerts     Alert[]
  watchedBy  Watchlist[]

  @@index([category])
  @@index([isActive])
}

// -----------------------------------------------------------------------------
// Sources (ports, wholesalers, factories, exchanges)
// -----------------------------------------------------------------------------

enum SourceType {
  PORT
  WHOLESALER
  EXCHANGE
  FACTORY
}

model Source {
  id        String     @id @default(cuid())
  slug      String     @unique
  nameAr    String
  nameEn    String
  type      SourceType
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  prices Price[]

  @@index([type])
  @@index([isActive])
}

// -----------------------------------------------------------------------------
// Prices (one row per commodity × source × date)
// -----------------------------------------------------------------------------

model Price {
  id          String   @id @default(cuid())
  commodityId String
  sourceId    String
  value       Decimal  @db.Decimal(12, 2)
  currency    String   @default("EGP")
  date        DateTime @db.Date
  notes       String?
  enteredById String?
  // Provenance: was this price observed/measured, or did we estimate it because
  // no source quoted this commodity today? Estimated rows render with a badge.
  isEstimated Boolean  @default(false)
  // Free-text reference to where the number came from (e.g. "VetPen 28-Apr-2026").
  sourceRef   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  commodity Commodity @relation(fields: [commodityId], references: [id], onDelete: Cascade)
  source    Source    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  enteredBy User?     @relation("EnteredBy", fields: [enteredById], references: [id], onDelete: SetNull)

  @@unique([commodityId, sourceId, date])
  @@index([date])
  @@index([commodityId, date])
  @@index([sourceId, date])
}

// -----------------------------------------------------------------------------
// Alerts — fire via cron when a price crosses threshold
// -----------------------------------------------------------------------------

enum AlertDirection {
  ABOVE
  BELOW
}

enum AlertChannel {
  EMAIL
  TELEGRAM
  BOTH
}

model Alert {
  id          String         @id @default(cuid())
  userId      String
  commodityId String
  threshold   Decimal        @db.Decimal(12, 2)
  direction   AlertDirection
  channel     AlertChannel   @default(EMAIL)
  isActive    Boolean        @default(true)
  lastFiredAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  commodity Commodity @relation(fields: [commodityId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([commodityId, isActive])
}

// -----------------------------------------------------------------------------
// Watchlist — user's default commodities shown on dashboard
// -----------------------------------------------------------------------------

model Watchlist {
  id          String   @id @default(cuid())
  userId      String
  commodityId String
  position    Int      @default(0)
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  commodity Commodity @relation(fields: [commodityId], references: [id], onDelete: Cascade)

  @@unique([userId, commodityId])
  @@index([userId])
}

// -----------------------------------------------------------------------------
// Telegram linking
// -----------------------------------------------------------------------------

model BotLink {
  id               String   @id @default(cuid())
  userId           String   @unique
  telegramChatId   String   @unique
  telegramUsername String?
  linkedAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Short-lived one-time codes issued by /dashboard/link-telegram and redeemed
// by the bot's /link CODE command. 15-minute TTL, single use.
model BotLinkCode {
  id        String   @id @default(cuid())
  userId    String
  code      String   @unique
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// -----------------------------------------------------------------------------
// Public API keys — sha256 hashed
// -----------------------------------------------------------------------------

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  hashedKey  String    @unique
  prefix     String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// -----------------------------------------------------------------------------
// Pro waitlist (MVP — payment not yet wired)
// -----------------------------------------------------------------------------

model WaitingList {
  id        String   @id @default(cuid())
  email     String   @unique
  locale    Locale   @default(ar)
  source    String?  // e.g. "pricing-page"
  createdAt DateTime @default(now())
}

// -----------------------------------------------------------------------------
// User-saved feed-mix formulas (cost calculator)
// -----------------------------------------------------------------------------

model Formula {
  id               String   @id @default(cuid())
  userId           String
  name             String
  items            Json     // [{ commoditySlug: string, percent: number }]
  totalTons        Decimal  @default(1) @db.Decimal(8, 2)
  herdSize         Int      @default(0)
  kgPerHeadPerDay  Decimal  @default(0) @db.Decimal(8, 2)
  fcr              Decimal  @default(0) @db.Decimal(6, 2)
  outputPricePerKg Decimal  @default(0) @db.Decimal(10, 2)
  outputKind       String   @default("meat") // meat | milk | eggs | custom
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// -----------------------------------------------------------------------------
// Operational tables — added 2026-05-01 in response to CTO board review.
// -----------------------------------------------------------------------------

/// Append-only audit trail for every admin price write or scraper upsert.
/// Mills (and we) can prove what was reported, by whom, when. Never deleted.
model PriceAudit {
  id           String   @id @default(cuid())
  priceId      String?  // null if the price was rejected before insert
  commoditySlug String
  sourceSlug   String
  date         DateTime @db.Date
  oldValue     Decimal? @db.Decimal(12, 2)
  newValue     Decimal  @db.Decimal(12, 2)
  /// 'admin_bulk' | 'photo_extract' | 'mill_submit' | 'scraper_mazra3ty' | 'scraper_elmorshd'
  source       String
  /// userId for human-driven actions, null for cron-driven scrapes.
  actorUserId  String?
  /// Free-form note: file_id, scraper run id, sourceRef etc.
  note         String?
  createdAt    DateTime @default(now())

  @@index([commoditySlug, date])
  @@index([source, createdAt])
  @@index([actorUserId])
}

/// Distributed rate-limiting table. Replaces the in-memory token bucket so
/// limits survive deploys and apply across multiple instances.
model RateLimit {
  /// Composite key: e.g. "watchlist:userId" or "vision:chatId" or "api:keyId".
  bucketKey  String   @id
  /// Tokens remaining in the current window.
  tokens     Int
  /// When the window started (ms).
  windowStart DateTime
  updatedAt  DateTime @updatedAt
}

/// Per-user daily Vision API quota — caps how many photo extractions a user
/// can run per Cairo day to bound Claude cost exposure.
model VisionQuota {
  /// Composite key: "userId:YYYY-MM-DD" (Cairo day).
  key        String   @id
  userId     String?
  used       Int      @default(0)
  date       DateTime @db.Date
  updatedAt  DateTime @updatedAt

  @@index([userId, date])
}
